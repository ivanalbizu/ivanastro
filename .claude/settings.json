{
  "permissions": {
    "allow": [
      "Bash(bash scripts/security/scan_secrets.sh:*)",
      "Bash(bash scripts/security/scan_code_patterns.sh:*)",
      "Bash(bash scripts/security/scan_configs.sh:*)",
      "Bash(bash scripts/security/scan_dependencies.sh:*)",
      "Bash(bash scripts/security/scan_prompt_injection.sh:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Read(/home/*/.ssh/**)",
      "Read(/home/*/.aws/**)",
      "Read(/home/*/.config/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Write(/home/*/.ssh/**)",
      "Write(/home/*/.aws/**)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Edit(/home/*/.ssh/**)",
      "Edit(/home/*/.aws/**)",
      "Edit(**/.env)",
      "Edit(**/.env.*)"
    ]
  }
}
